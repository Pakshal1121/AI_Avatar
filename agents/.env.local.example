# LiveKit
LIVEKIT_URL=your_livekit_ws_url
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Avatar - Beyond Presence (you can choose other avatar providers)
BEY_API_KEY=<your-bey-api-key>

# Avatar - Replace avatar_hedra_image.jpg with your own JPEG image
HEDRA_API_KEY=<your-hedra-api-key>

ANAM_API_KEY=<your-anam-api-key>
ANAM_AVATAR_ID=<your-anam-avatar-id>

# STT
DEEPGRAM_API_KEY=<your-deepgram-api-key>

# LLM
OPENAI_API_KEY=<your-openai-api-key>
# TTS
CARTESIA_API_KEY=<your-cartesia-api-key>

#db
PORT=8000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=ielts

JWT_SECRET=your_jwt_secret_key
# Listening Coach — passage generation model
LISTENING_PASSAGE_MODEL=<your-listening-passage-model>
