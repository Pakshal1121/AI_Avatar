# Frontend -> Unified API (Auth + Reading + Writing)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8002

# Unified FastAPI Backend (Phase 1): Reading + Writing + Token
# Used by /writing/examiner and /reading/examiner
NEXT_PUBLIC_BACKEND_URL=http://localhost:8002
NEXT_PUBLIC_READING_BACKEND_URL=http://localhost:8002

# LiveKit
LIVEKIT_URL=your_livekit_ws_url
NEXT_PUBLIC_LIVEKIT_URL=your_livekit_ws_url
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# LiveKit API
NEXT_PUBLIC_CONN_DETAILS_ENDPOINT=/api/livekit/connection-details
NEXT_PUBLIC_SHOW_SETTINGS_MENU=false
NEXT_PUBLIC_LK_RECORD_ENDPOINT=/api/livekit/record

# Host / Agent
NEXT_PUBLIC_HOST_NAME=your_host_name
NEXT_PUBLIC_HOST_IMAGE=your_host_image
NEXT_PUBLIC_AGENT_NAME=your_agent_name
NEXT_PUBLIC_VOICE_AGENT_IMAGE=your_voice_agent_image

OPENAI_API_KEY=your_openai_api_key